{
  "title": "System Health",
  "panels": [
    {
      "title": "Request Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, http_request_duration_seconds{service=\"orchestrator\"})"
        }
      ]
    },
    {
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])"
        }
      ]
    }
  ]
}
